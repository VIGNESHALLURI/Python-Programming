#Hybrid Inheritance
class Person:
    def common(self):
        print("All are humans")

class Student(Person):
    def study(self):
        print("Student studies")

class Employee(Person):
    def work(self):
        print("Employee works")

class WorkingStudent(Student, Employee):
    def manage(self):
        print("Working student manages both study and job")

ws = WorkingStudent()
ws.common()
ws.study()
ws.work()
ws.manage()

class Vehicle:
    def start(self):
        print("Vehicle starting")

class Car(Vehicle):
    def start(self):
        print("Car starts with key")

class Bike(Vehicle):
    def start(self):
        print("Bike starts with kick")

vehicles = [Car(), Bike()]

for v in vehicles:
    v.start()


