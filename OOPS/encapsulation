class SchoolBag:
    def __init__(self):
        self.books = []       
        self.stationery = []  

    def add_book(self, book):
        self.books.append(book)
        print(f"Added book: {book}")

    def remove_book(self, book):
        if book in self.books:
            self.books.remove(book)
            print(f"Removed book: {book}")
        else:
            print(f"{book} not found")

    def view_books(self):
        return self.books

bag = SchoolBag()
bag.add_book("Math")
bag.add_book("Science")
print("Books in bag:", bag.view_books())
bag.remove_book("Math")
print("Books after removing Math:", bag.view_books())
