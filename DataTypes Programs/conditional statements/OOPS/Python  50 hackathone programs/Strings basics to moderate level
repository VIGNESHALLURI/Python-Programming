#take a string. replace vowels in the string with letter z.
#After that print the string.
"""
s = input("Enter a string: ")

vowels = "aeiouAEIOU"
result = ""

for ch in s:
    if ch in vowels:
        result += "z"
    else:
        result += ch

print("Modified string:", result)"""

