#take a string. write logic to count how many no of times each letter is repeating in that string. 
#[letter occurrences] 
"""
s = "palle tech"

for i in range(len(s)):

    already = False
    for j in range(i):
        if s[i] == s[j]:
            already = True
            break

    if not already:
        count = 0
        for k in range(len(s)):
            if s[i] == s[k]:
                count += 1

        print(s[i], "=", count)"""

