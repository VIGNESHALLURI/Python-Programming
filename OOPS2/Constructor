#Same as above question, print student object values with object without calling display()
class Student:
    def __init__(self, sno, name, subject):
        self.sno = sno
        self.name = name
        self.subject = subject

    def __str__(self):
        return f"Student No: {self.sno}, Name: {self.name}, Subject: {self.subject}"

s1 = Student(1, 'Ramesh', 'Python')
s2 = Student(2, 'Suresh', 'AI')

print(s1)
print(s2)

